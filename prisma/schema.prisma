generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Models ────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Models ────────────────────────────────────────────

enum Plan {
  FREE
  PREMIUM
  VERIFIED
}

enum UserRole {
  USER
  MOD
  ADMIN
}

enum ProfileLayout {
  STANDARD
  CLASSIC
  CARD
  GRID
  MINIMAL
  BOXES
}

enum SocialPlatform {
  DISCORD
  YOUTUBE
  TWITTER
  GITHUB
  TIKTOK
  INSTAGRAM
  SPOTIFY
  TWITCH
  STEAM
  TELEGRAM
  SNAPCHAT
  REDDIT
  LINKEDIN
  FACEBOOK
  PAYPAL
  SOUNDCLOUD
  CASHAPP
  PINTEREST
  KICK
  XBOX
  PLAYSTATION
  APPLE_MUSIC
  THREADS
  PATREON
  BITCOIN
  ETHEREUM
  VK
  BEHANCE
  DRIBBBLE
  FIGMA
  KICKSTARTER
  KOFI
  ONLYFANS
  RUMBLE
  EMAIL
  WEBSITE
  CUSTOM
}

enum WidgetType {
  DISCORD_SERVER
  DISCORD_USERS
  STAFF_LIST
  YOUTUBE_CHANNEL
  GITHUB_PROFILE
  SPOTIFY_NOW_PLAYING
  STEAM_PROFILE
  ROBLOX_PROFILE
  CUSTOM_EMBED
}

enum BadgeType {
  PREMIUM
  VERIFIED
  CUSTOM
  STAFF
  ADMIN
  EARLY_SUPPORTER
  DISCORD_ROLE
  DISCORD_MEMBER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  username      String?   @unique
  displayName   String?
  bio           String?   @db.Text
  location      String?
  occupation    String?   // Developer, Community Manager, Designer, etc.
  gender        String?   // Male, Female, Non-binary, Prefer not to say, etc.
  relationship  String?   // Single, Taken, Complicated, etc.
  avatarUrl           String?
  bannerUrl           String?
  avatarDecorationUrl String?
  plan                Plan      @default(FREE)
  role                UserRole  @default(USER)
  verified            Boolean   @default(false)
  verifiedAt          DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  profile           Profile?
  links             Link[]
  socialLinks       SocialLink[]
  widgets           Widget[]
  badges            Badge[]
  discordConnection DiscordConnection?
  guestbookEntries  GuestbookEntry[]   @relation("GuestbookAuthor")
  guestbookReceived GuestbookEntry[]   @relation("GuestbookOwner")
  profileViews      ProfileView[]
  pageAliases       PageAlias[]
  payments          Payment[]
  templates         Template[]
  templateFavorites TemplateFavorite[]
}

model Profile {
  id                String        @id @default(cuid())
  userId            String        @unique
  layout            ProfileLayout @default(STANDARD)
  theme             Json          @default("{}")
  revealScreen      Json          @default("{}")
  cursorEffect      String?
  cursorUrl         String?
  cursorTrail       String?   // Cursor trail/shadow: crows, stars, angels, sparkles, hearts, skulls, etc.
  backgroundEffect  String?
  bgAnimation       String?   // Background animation: flying-crows, disco, floating-shapes, fireflies, etc.
  backgroundUrl     String?
  backgroundType    String?       @default("image")
  musicUrl          String?
  musicTitle        String?
  musicDisplayMode  String?       @default("bar")
  entranceAnimation String?
  customCss         String?       @db.Text
  seoTitle          String?
  seoDescription    String?
  seoImage          String?
  isPublic          Boolean       @default(true)
  totalViews        Int           @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Link {
  id            String    @id @default(cuid())
  userId        String
  title         String
  url           String
  description   String?
  icon          String?
  emoji         String?
  style         String    @default("default") // default | gradient | neon | minimal | glass | solid
  bgColor       String?
  textColor     String?
  borderColor   String?
  iconColor     String?
  cta           String?   // Custom call-to-action text e.g. "Visit", "Buy now"
  pinned        Boolean   @default(false)
  nsfw          Boolean   @default(false)
  password      String?
  startsAt      DateTime?
  endsAt        DateTime?
  order         Int       @default(0)
  clicks        Int       @default(0)
  lastClickedAt DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, order])
}

model SocialLink {
  id          String         @id @default(cuid())
  userId      String
  platform    SocialPlatform
  url         String
  displayName String?
  order       Int            @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Widget {
  id       String     @id @default(cuid())
  userId   String
  type     WidgetType
  config   Json       @default("{}")
  order    Int        @default(0)
  isActive Boolean    @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Badge {
  id        String    @id @default(cuid())
  userId    String
  type      BadgeType
  label     String?
  icon      String?
  color     String?
  grantedAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, label])
}

model DiscordConnection {
  id              String   @id @default(cuid())
  userId          String   @unique
  discordId       String   @unique
  discordUsername    String?
  discordDisplayName String?
  discordAvatarUrl   String?
  discordBannerUrl       String?
  avatarDecorationUrl    String?
  nitroType              Int      @default(0)
  publicFlags        Int      @default(0)
  accessToken        String?  @db.Text
  refreshToken       String?  @db.Text
  guildIds           String[] @default([])
  autoSyncAvatar     Boolean  @default(true)
  autoSyncBanner     Boolean  @default(true)
  showPresence    Boolean  @default(true)
  showActivity    Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GuestbookEntry {
  id             String   @id @default(cuid())
  profileUserId  String
  authorUserId   String?
  authorName     String?
  message        String   @db.Text
  isApproved     Boolean  @default(false)
  createdAt      DateTime @default(now())

  profileOwner User  @relation("GuestbookOwner", fields: [profileUserId], references: [id], onDelete: Cascade)
  author       User? @relation("GuestbookAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
}

model ProfileView {
  id            String   @id @default(cuid())
  profileUserId String
  visitorIpHash String?
  referrer      String?
  country       String?
  device        String?
  createdAt     DateTime @default(now())

  profileUser User @relation(fields: [profileUserId], references: [id], onDelete: Cascade)

  @@index([profileUserId, createdAt])
}

model PageAlias {
  id        String   @id @default(cuid())
  userId    String
  alias     String   @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  stripePaymentId String?       @unique
  plan            String
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("usd")
  status          PaymentStatus @default(PENDING)
  createdAt       DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Template System ────────────────────────────────────────

model Template {
  id            String   @id @default(cuid())
  authorId      String
  name          String
  description   String?  @db.Text
  previewUrl    String?  // screenshot / thumbnail URL
  themeBlob     Json     @default("{}") // full theme settings snapshot
  tags          String[] @default([])
  isVerified    Boolean  @default(false) // official ToxicLinks templates
  isPublic      Boolean  @default(true)
  useCount      Int      @default(0)
  starCount     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  author    User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  favorites TemplateFavorite[]

  @@index([authorId])
  @@index([useCount(sort: Desc)])
  @@index([starCount(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model TemplateFavorite {
  id         String   @id @default(cuid())
  userId     String
  templateId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([userId, templateId])
}
